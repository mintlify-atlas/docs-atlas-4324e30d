  "keyFeatures": [
    "Multi-format eBook support (EPUB, PDF, MOBI, AZW3, CBZ, and more)",
    "Automatic metadata fetching from Open Library, Apple Books, and Goodreads",
    "Cover image extraction, search, and direct embedding into EPUB files",
    "Series tracking, tagging, and bulk operations",
    "Configurable file rename schemes and folder organization",
    "Send books to Kindle or any eReader via SMTP/email",
    "Self-hosted with Docker, persistent library stored in a volume",
    "Session-based authentication with secure password hashing"
  ],
